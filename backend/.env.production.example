# ============================================
# 시공코어 백엔드 — 프로덕션 환경 변수
# .env 파일로 복사 후 실제 값으로 교체: cp .env.production.example .env
# ============================================

# 데이터베이스
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/sigongcore

# 보안 / JWT (최소 32자 이상의 강력한 랜덤 문자열)
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY_MIN_32_CHARS
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# 파일 업로드
UPLOAD_DIR=/app/uploads

# CORS (프로덕션 도메인)
CORS_ORIGINS=["https://admin.sigongcore.com","https://mobile.sigongcore.com"]

# 내부 크론잡 인증
INTERNAL_RENEWAL_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET

# ============================================
# 외부 서비스 (프로덕션 키로 교체 필요)
# ============================================

# 토스페이먼츠
TOSS_CLIENT_KEY=live_ck_REPLACE_WITH_REAL_KEY
TOSS_SECRET_KEY=live_sk_REPLACE_WITH_REAL_KEY
TOSS_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
TOSS_IS_MOCK=false

# 알리고 SMS/알림톡
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=
ALIGO_IS_MOCK=false

# 모두싸인 전자서명
MODUSIGN_API_KEY=
MODUSIGN_IS_MOCK=false
# MODUSIGN_API_URL=https://api.modusign.co.kr
# MODUSIGN_CALLBACK_URL=https://api.sigongcore.com/api/v1/modusign/callback

# 팝빌 세금계산서
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
POPBILL_CORP_NUM=
POPBILL_IS_MOCK=false
POPBILL_IS_TEST=false

# 사업자 진위확인 (국세청)
BUSINESS_VERIFICATION_API_KEY=
BUSINESS_VERIFICATION_IS_MOCK=false

# Firebase FCM 푸시
FIREBASE_IS_MOCK=false
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
# FIREBASE_CREDENTIALS_JSON=  (CREDENTIALS_PATH 대신 JSON 문자열 사용 가능)

# Google AI (Gemini)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
