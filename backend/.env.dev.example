# ============================================
# 시공ON 백엔드 — 개발 환경 변수
# .env 파일로 복사하여 사용: cp .env.dev.example .env
# ============================================

# 데이터베이스
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5444/yunigreen

# 보안 / JWT
JWT_SECRET=dev-secret-key-do-not-use-in-production
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# 앱 설정
DEBUG=true
ENABLE_DOCS=true
# APP_NAME=SigongOn API
# APP_VERSION=0.1.0

# 파일 업로드
UPLOAD_DIR=./uploads
# MAX_UPLOAD_SIZE_MB=10

# CORS (개발 서버)
CORS_ORIGINS=["http://localhost:3033","http://localhost:3034","http://localhost:3133","http://localhost:3134"]

# Snowflake ID
# SNOWFLAKE_WORKER_ID=1

# ============================================
# 외부 서비스 (개발 시 모두 Mock 모드)
# 실서비스 연동 테스트 시 _IS_MOCK=false + 키 입력
# ============================================

# 토스페이먼츠
TOSS_IS_MOCK=true
# TOSS_CLIENT_KEY=test_ck_xxx
# TOSS_SECRET_KEY=test_sk_xxx
# TOSS_WEBHOOK_SECRET=xxx

# 알리고 SMS/알림톡
ALIGO_IS_MOCK=true
# ALIGO_API_KEY=
# ALIGO_USER_ID=
# ALIGO_SENDER=010-0000-0000

# 모두싸인 전자서명
MODUSIGN_IS_MOCK=true
# MODUSIGN_API_KEY=
# MODUSIGN_API_URL=https://api.modusign.co.kr
# MODUSIGN_CALLBACK_URL=

# 팝빌 세금계산서
POPBILL_IS_MOCK=true
# POPBILL_LINK_ID=
# POPBILL_SECRET_KEY=
# POPBILL_CORP_NUM=
# POPBILL_IS_TEST=true

# 사업자 진위확인 (국세청)
BUSINESS_VERIFICATION_IS_MOCK=true
# BUSINESS_VERIFICATION_API_KEY=

# Firebase FCM 푸시
FIREBASE_IS_MOCK=true
# FIREBASE_CREDENTIALS_PATH=
# FIREBASE_CREDENTIALS_JSON=

# Google AI (Gemini)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ============================================
# 정책 플래그
# ============================================
# LABOR_CODE_VALIDATION_ENABLED=true
# LABOR_DEPLOYMENT_GATE_ENABLED=true
