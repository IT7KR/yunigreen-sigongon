  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "predev": "node scripts/dev-guard.mjs",
    "dev": "next dev --port 3033",
    "start": "next start --port 3033",
    "prebuild": "turbo build --filter='./packages/*'",
    "build": "next build",
